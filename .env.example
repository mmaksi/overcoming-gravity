# Data backend: "json" (local file db, default in development)
# or "supabase" (default in production builds).
DATA_BACKEND=json

# Required when DATA_BACKEND=supabase — from your Supabase project settings.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Production setup:
# 1. Apply supabase/migrations/0001_init.sql (supabase db push, or SQL editor)
# 2. Seed content: supabase/seed.sql (regenerate: node scripts/export-seed-sql.mjs)
# 3. Grant yourself admin: update profiles set is_admin = true where email = '...';
