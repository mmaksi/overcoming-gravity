# Data backend: "json" (local file db, default in development)
# or "supabase" (default in production builds).
DATA_BACKEND=json

# Required when DATA_BACKEND=supabase — from your Supabase project settings.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Public base URL of the deployed app — used to build the Google OAuth redirect
# (`${NEXT_PUBLIC_SITE_URL}/auth/callback`). e.g. https://your-app.vercel.app.
# For local Supabase-mode testing use http://localhost:3000. Only needed when
# DATA_BACKEND=supabase; in JSON/dev mode sign-in is a no-op.
NEXT_PUBLIC_SITE_URL=

# Google sign-in credentials (Google Cloud Console → APIs & Services →
# Credentials → OAuth client ID → "Web application").
# IMPORTANT: these two values are pasted into the SUPABASE DASHBOARD
# (Authentication → Providers → Google), NOT read by the app. They live here
# only as a checklist of what you need to create/fill.
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=

# --- Billing -----------------------------------------------------------------
# Payment provider behind the billing seam (src/lib/billing). Only "stripe"
# is implemented today.
BILLING_PROVIDER=stripe

# Stripe secret key (Dashboard → Developers → API keys). Use the sk_test_…
# key first; the app auto-creates the "Cali Pro" product and its two prices
# (€25/month, €197/year) by lookup key on first checkout.
STRIPE_SECRET_KEY=

# Webhook signing secret. Create a webhook endpoint pointing at
# ${NEXT_PUBLIC_SITE_URL}/api/billing/stripe/webhook with the events
# checkout.session.completed, customer.subscription.created,
# customer.subscription.updated, customer.subscription.deleted.
# (Locally: `stripe listen --forward-to localhost:3000/api/billing/stripe/webhook`.)
# Without it, renewals/cancellations only sync when the user visits Settings.
STRIPE_WEBHOOK_SECRET=

# Service-role key (Supabase → Project Settings → API). Required in Supabase
# mode for billing writes: subscription columns are trigger-protected against
# user sessions, so webhooks/checkout/sync write with this key. Server-only —
# never expose it with a NEXT_PUBLIC_ prefix.
SUPABASE_SERVICE_ROLE_KEY=

# Stripe Customer Portal (Settings → "Manage subscription") needs its default
# configuration saved once in the Stripe Dashboard → Settings → Billing →
# Customer portal.

# Production setup:
# 1. Apply supabase/migrations/0001_init.sql (supabase db push, or SQL editor)
# 2. Seed content: supabase/seed.sql (regenerate: node scripts/export-seed-sql.mjs)
# 3. Grant yourself admin: update profiles set is_admin = true where email = '...';
# 4. Google sign-in: create an OAuth client in Google Cloud Console, add the
#    redirect URI https://<project-ref>.supabase.co/auth/v1/callback, then paste
#    its Client ID + Secret into Supabase → Authentication → Providers → Google.
#    Add ${NEXT_PUBLIC_SITE_URL}/auth/callback (and http://localhost:3000/auth/
#    callback) to Supabase → Authentication → URL Configuration → Redirect URLs.
