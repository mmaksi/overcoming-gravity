{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "dev",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3000
    },
    {
      "name": "landing",
      "runtimeExecutable": "npm",
      "runtimeArgs": [
        "--prefix",
        "../cali-pro-landing",
        "run",
        "dev",
        "--",
        "--port",
        "3400"
      ],
      "port": 3400
    },
    {
      "name": "dev-json",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--", "--port", "3210"],
      "port": 3210,
      "env": {
        "DATA_BACKEND": "json",
        "DATA_FILE": "data/db.json"
      }
    }
  ]
}
